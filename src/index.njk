  <!-- ABOUT TOWN -->
  <section class="section">
    <div class="container">
      <div style="display:grid; grid-template-columns: 1fr 1fr; gap: 72px; align-items: start;">
        <div>
          <div class="section-eyebrow"><span aria-hidden="true">🌲</span> Berkshire County, Massachusetts</div>
          <h2 style="margin-bottom:20px;">Welcome to<br>Florida, MA</h2>
          <div style="width:48px; height:3px; background:var(--clr-primary); margin-bottom:28px; border-radius:2px;"></div>
          <p>Florida is a town in Berkshire County, Massachusetts, United States. Part of the Pittsfield Metropolitan Statistical Area, it is home to the eastern portal of the Hoosac Tunnel and sits at an elevation of 2,172 feet — the highest point on the Mohawk Trail.</p>
          <p>Incorporated in 1805, Florida is governed by an open town meeting form of government, led by a Board of Selectmen and served by a dedicated team of departments and volunteers.</p>
          <div style="margin-top:32px; display:flex; gap:12px; flex-wrap:wrap;">
            <a href="/history.html" class="btn btn--primary">Read Our History</a>
            <a href="/officials.html" class="btn btn--outline">Meet Our Officials</a>
          </div>
        </div>
        <div>
          <div style="background:var(--clr-light); border-radius:var(--radius-lg); overflow:hidden; border:1px solid var(--clr-border);">
            <img src="/images/FloridaMA.jpg" alt="Entering Florida, MA on the Mohawk Trail" style="width:100%; height:220px; object-fit:cover; object-position:center 55%;" />
          </div>
          <div class="stats-bar" style="margin-top:0; border-top:none; border-radius:0 0 var(--radius) var(--radius);">
            <div class="stat-item"><div class="stat-item__number">1805</div><div class="stat-item__label">Incorporated</div></div>
            <div class="stat-item"><div class="stat-item__number">2,172<span style="font-size:1rem;">ft</span></div><div class="stat-item__label">Peak Elevation</div></div>
            <div class="stat-item"><div class="stat-item__number">92%</div><div class="stat-item__label">Forest Cover</div></div>
            <div class="stat-item"><div class="stat-item__number">4.75<span style="font-size:1rem;">mi</span></div><div class="stat-item__label">Hoosac Tunnel</div></div>
          </div>
        </div>
      </div>
    </div>
  </section>

