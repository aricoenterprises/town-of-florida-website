---
layout: base.njk
title: "Town Officials — Town of Florida, MA"
description: "Town of Florida, MA — List of Town Officials, departments, and contact information."
navKey: officials
permalink: officials.html
---

  <div class="page-header">
    <div class="container">
      <p class="page-header__eyebrow">Town of Florida, MA</p>
      <h1 class="page-header__title">Town Officials &amp; Departments</h1>
      <p class="page-header__desc">Contact information, office hours, and staff for all town departments and boards.</p>
    </div>
  </div>

  <div class="breadcrumb container">
    <a href="/">Home</a><span>›</span> Town Officials
  </div>

  <section class="section">
    <div class="container">

      <div class="dept-filter">
        <button class="dept-filter__btn active" data-filter="all">All Departments</button>
        <button class="dept-filter__btn" data-filter="elected">Elected Boards</button>
        <button class="dept-filter__btn" data-filter="admin">Administration</button>
        <button class="dept-filter__btn" data-filter="safety">Public Safety</button>
        <button class="dept-filter__btn" data-filter="services">Services</button>
        <button class="dept-filter__btn" data-filter="inspectors">Inspectors &amp; Permits</button>
      </div>

      {% for dept in officials.departments %}
      <div class="dept-section" id="{{ dept.anchorId }}" data-category="{{ dept.category }}">
        <div class="dept-section__header">
          <div class="dept-section__icon">
            <svg viewBox="0 0 24 24" fill="none" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round">
              {{ iconSvgs[dept.icon] | safe }}
            </svg>
          </div>
          <div>
            <div class="dept-section__title">{{ dept.title }}</div>
            {% if dept.subtitle %}<div class="dept-section__sub">{{ dept.subtitle }}</div>{% endif %}
          </div>
        </div>

        <div class="card-grid">
          {% for official in dept.officials %}
          <div class="official-card"{% if official.isHighlighted %} style="background:var(--clr-light);"{% endif %}>
            <div class="official-card__name">{{ official.name }}</div>
            <div class="official-card__divider"></div>
            {% if official.role %}<div class="official-card__role">{{ official.role }}</div>{% endif %}

            {%- set hasInfo = official.hours or official.address or official.phone or official.email or official.notes or (official.links and official.links | length) -%}
            {% if hasInfo %}
            <div class="official-card__info">
              {%- if official.hours -%}{{ official.hours }}<br>{%- endif -%}
              {%- if official.address -%}{{ official.address | nl2br | safe }}<br>{%- endif -%}
              {%- if official.phone -%}Phone: {{ official.phone }}<br>{%- endif -%}
              {%- if official.email -%}<a href="mailto:{{ official.email }}">{{ official.email }}</a>{%- if official.notes or (official.links and official.links | length) -%}<br>{%- endif -%}{%- endif -%}
              {%- if official.notes -%}{{ official.notes | nl2br | safe }}{%- if official.links and official.links | length -%}<br>{%- endif -%}{%- endif -%}
              {%- for link in official.links -%}
              <a href="{{ link.url }}"{% if 'http' in link.url %} target="_blank" rel="noopener"{% endif %}>{{ link.label }}</a>{%- if not loop.last -%}<br>{%- endif -%}
              {%- endfor -%}
            </div>
            {% endif %}
          </div>
          {% endfor %}
        </div>
      </div>
      {% endfor %}

    </div>
  </section>
